<style>
  /* Container to hide overflowing cards */
  .marquee-wrapper {
    overflow: hidden;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 20px 0;
  }

  /* The track holds the sets side by side */
  .marquee-track {
    width: max-content !important;
    min-width: max-content !important;
    display: flex;
    flex-wrap: nowrap !important; /* STRICTLY forces a single line to prevent overlap */
    gap: 20px;
  }

  .marquee-content {
    display: flex;
    flex-wrap: nowrap !important; /* Prevents internal cards from stacking */
    gap: 20px;
    flex-shrink: 0 !important;
    min-width: max-content !important;
  }

  /* --- ONE-TIME ENTRANCE ANIMATIONS (Starts Blank) --- */
  .right-to-left-track {
    animation: slideInFromRight 0.5s ease-out forwards;
  }

  .left-to-right-track {
    animation: slideInFromLeft 0.5s ease-out forwards;
  }

  /* --- APPLY INFINITE ANIMATIONS --- */
  .right-to-left-track .marquee-content {
    animation: scrollLeft 60s linear infinite;
  }

  .left-to-right-track .marquee-content {
    animation: scrollRight 60s linear infinite;
  }

  /* Hover to pause */
  .marquee-track:hover .marquee-content {
    animation-play-state: paused;
  }

  /* --- THE KEYFRAMES --- */
  @keyframes slideInFromRight {
    0% {
      transform: translateX(100vw);
    }
    100% {
      transform: translateX(0);
    }
  }

  @keyframes slideInFromLeft {
    0% {
      transform: translateX(-100vw);
    }
    100% {
      transform: translateX(0);
    }
  }

  @keyframes scrollLeft {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(-100% - 20px));
    }
  }

  @keyframes scrollRight {
    from {
      transform: translateX(calc(-100% - 20px));
    }
    to {
      transform: translateX(0);
    }
  }

  /* Card Styling */
  .product-card {
    width: 250px !important;
    flex-shrink: 0 !important;
    box-sizing: border-box;
    background: white;
    padding: 20px;
    text-align: center;
    font-family: sans-serif;
  }
  .image-placeholder {
    width: 100%;
    height: 200px;
    background-color: #e0e0e0;
    margin: 15px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .image-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .product-vendor {
    font-size: 12px;
    color: #7a7a7a;
    text-transform: uppercase;
    line-height: 1.5;
  }
  .marquee-content h4 {
    margin: 0;
    font-size: 14px;
    height: 62px;
    font-weight: 600;
    white-space: wrap;
    text-transform: uppercase;
  }
  .marquee-content p {
    margin: 0;
    font-size: 12px;
    color: #121212;
    line-height: 1.5;
    text-transform: uppercase;
  }

  @media (max-width: 425px) {
    .marquee-content h4 {
      font-size: 11px;
    }
    .marquee-content p {
      font-size: 12px;
    }
    .product-vendor {
      font-size: 8px;
    }
  }
</style>

<section>
  <h2 class="tw:text-[24px]! tw:text-black! tw:font-bold! tw:px-[20px]! tw:py-[20px]!">
    {{ section.settings.heading }}
  </h2>
  <div class="marquee-wrapper">
    <div class="marquee-track right-to-left-track">
      <div class="marquee-content">
        {% for product in section.settings.collection_right.products %}
          <a href="{{product.url}}" class="product-card">
            <h4>{{ product.title }}</h4>
            <div class="image-placeholder">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 250 }}"
                  alt="{{ product.title }}"
                  width="250"
                  height="200"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <span class="product-vendor">{{ product.vendor }}</span>
            <p>{{ product.price | money }}</p>
          </a>
        {% endfor %}
      </div>
    </div>
    {% comment %}
      <div class="marquee-track left-to-right-track">
        <div class="marquee-content">
          {% for product in section.settings.collection_left.products %}
            <div class="product-card">
              <h4>{{ product.title }}</h4>
              <div class="image-placeholder">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 250 }}"
                    alt="{{ product.title }}"
                    width="250"
                    height="200"
                    loading="lazy"
                  >
                {% endif %}
              </div>
              <span class="product-vendor">{{ product.vendor }}</span>
              <p>{{ product.price | money }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endcomment %}
  </div>
</section>

<script>
  function initMarquee() {
    // THE FIX: Select only tracks that haven't been initialized yet
    // This stops the Shopify editor from multiplying the cards infinitely on save
    const tracks = document.querySelectorAll('.marquee-track:not(.is-initialized)');

    tracks.forEach((track) => {
      // Mark this track so the script ignores it if it runs again
      track.classList.add('is-initialized');

      const content = track.querySelector('.marquee-content');
      if (!content) return;

      const originalCards = Array.from(content.children);
      if (originalCards.length === 0) return;

      // 1. Calculate widths
      const cardWidth = originalCards[0].offsetWidth;
      const gap = parseFloat(window.getComputedStyle(content).gap) || 0;
      const totalItemWidth = cardWidth + gap;

      if (totalItemWidth === 0) return;

      // 2. Figure out base screen fill
      const screenWidth = window.innerWidth;
      const requiredWidth = screenWidth * 1.5;
      const targetCardCount = Math.ceil(requiredWidth / totalItemWidth);

      // 3. Ensure the final count is a perfect multiple to prevent seams
      let finalCardCount = targetCardCount;
      const remainder = targetCardCount % originalCards.length;
      if (remainder !== 0) {
        finalCardCount += originalCards.length - remainder;
      }

      // 4. Clone to the corrected multiple
      let currentCount = originalCards.length;
      let indexToClone = 0;

      while (currentCount < finalCardCount) {
        const cardToClone = originalCards[indexToClone % originalCards.length];
        content.appendChild(cardToClone.cloneNode(true));

        currentCount++;
        indexToClone++;
      }

      // 5. Duplicate for the CSS loop
      const contentClone = content.cloneNode(true);
      contentClone.setAttribute('aria-hidden', 'true');
      track.appendChild(contentClone);
    });
  }

  // Run the script safely
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMarquee);
  } else {
    initMarquee();
  }

  // Also hook into Shopify's editor event so it recalculates if you change settings!
  document.addEventListener('shopify:section:load', initMarquee);
</script>

{% schema %}
{
  "name": "Home Featured Product",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FEATURED"
    },
    {
      "type": "collection",
      "id": "collection_right",
      "label": "Collection Right"
    }
    // {
    //   "type": "collection",
    //   "id": "collection_left",
    //   "label": "Collection Left"
    // }
  ]
}
{% endschema %}
